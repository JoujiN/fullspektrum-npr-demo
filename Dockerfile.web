FROM node:22-bookworm-slim AS build

ARG FLOWSTATE_REPO=https://github.com/baphled/flowstate.git
ARG FLOWSTATE_REF=feature/vue-ui-rebase

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates git \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /src
RUN git clone --depth 1 --branch "$FLOWSTATE_REF" "$FLOWSTATE_REPO" flowstate

WORKDIR /src/flowstate/web
RUN npm ci
RUN npm run build

FROM nginx:1.27-alpine

COPY --from=build /src/flowstate/web/dist /usr/share/nginx/html
COPY nginx/default.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
