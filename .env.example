# FullSpektrum NPR demo backend runtime.
# Copy to .env for local checks, or to /etc/fullspektrum/flowstate.env on a VPS.

# FlowState source. Use an immutable tag or commit SHA for deployments.
FLOWSTATE_REPO=https://github.com/baphled/flowstate.git
FLOWSTATE_REF=REPLACE_WITH_PINNED_COMMIT_OR_TAG

# FlowState runs as a private localhost service behind an HTTPS reverse proxy.
FLOWSTATE_HOST=127.0.0.1
FLOWSTATE_PORT=8080

# FlowState config/data roots. The helper writes under these XDG base dirs.
XDG_CONFIG_HOME=/var/lib/fullspektrum/flowstate/config
XDG_DATA_HOME=/var/lib/fullspektrum/flowstate/data
FULLSPEKTRUM_ASSET_ROOT=/opt/fullspektrum/npr-demo

# Provider credentials.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# FlowState API auth. Generate values with:
#   openssl rand -base64 32
FLOWSTATE_AUTH_ENABLED=true
FLOWSTATE_AUTH_MODE=per-deployment-login
FLOWSTATE_AUTH_SECRET=
FLOWSTATE_AUTH_CSRF_KEY=
FLOWSTATE_AUTH_PRINCIPAL_ID=fullspektrum-demo
FLOWSTATE_AUTH_DISPLAY_NAME="FullSpektrum Demo"
FLOWSTATE_AUTH_SECURE_COOKIES=true
FLOWSTATE_AUTH_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:5173

# Qdrant sidecar. docker-compose.yml binds Qdrant to localhost only.
# Leave QDRANT_URL empty for no-recall/no-embeddings mode.
QDRANT_BIND_HOST=127.0.0.1
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=
QDRANT_COLLECTION=fullspektrum-npr
QDRANT_API_KEY=

# Optional/external embeddings. Do not run Ollama as a default Docker service here.
# Point this at a host-local or remote Ollama deployment when GPU capacity exists.
OLLAMA_HOST=
OLLAMA_MODEL=llama3.2
EMBEDDING_MODEL=
