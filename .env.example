# FullSpektrum NPR demo runtime.
# Copy to .env and fill the secret values before starting the stack.

# FlowState build source. Set FLOWSTATE_REF to the branch/tag/commit approved for the demo.
FLOWSTATE_REPO=https://github.com/baphled/flowstate.git
FLOWSTATE_REF=feature/vue-ui-rebase

# Public HTTP surface for the demo web UI.
WEB_PORT=8081

# FlowState API service. Keep this internal to Compose unless intentionally exposing it.
FLOWSTATE_PORT=8080
FLOWSTATE_HOST=0.0.0.0

# Provider credentials.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# FlowState API auth. Generate values with:
#   openssl rand -base64 32
FLOWSTATE_AUTH_ENABLED=true
FLOWSTATE_AUTH_MODE=per-deployment-login
FLOWSTATE_AUTH_SECRET=
FLOWSTATE_AUTH_CSRF_KEY=
FLOWSTATE_AUTH_PRINCIPAL_ID=fullspektrum-demo
FLOWSTATE_AUTH_DISPLAY_NAME="FullSpektrum Demo"
FLOWSTATE_AUTH_SECURE_COOKIES=false
FLOWSTATE_AUTH_ALLOWED_ORIGINS=localhost:*,127.0.0.1:*

# Recall and embeddings.
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=fullspektrum-npr
QDRANT_API_KEY=
OLLAMA_HOST=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text
