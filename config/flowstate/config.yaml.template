providers:
  default: anthropic
  anthropic:
    model: "${ANTHROPIC_MODEL}"
  ollama:
    host: "${OLLAMA_HOST}"
    model: llama3.2
qdrant:
  url: "${QDRANT_URL}"
  collection: "${QDRANT_COLLECTION}"
  api_key: "${QDRANT_API_KEY}"
embedding_model: "${EMBEDDING_MODEL}"
agent_dir: "${FLOWSTATE_CONFIG_DIR}/agents"
skill_dir: "${FLOWSTATE_CONFIG_DIR}/skills"
schema_dir: "${FLOWSTATE_CONFIG_DIR}/schemas"
gates_dir: "${FLOWSTATE_CONFIG_DIR}/gates"
data_dir: "${FLOWSTATE_DATA_DIR}"
default_agent: npr-onboarding
log_level: info
auth:
  enabled: true
  mode: per-deployment-login
  secret: "${FLOWSTATE_AUTH_SECRET}"
  principal_id: fullspektrum-demo
  display_name: FullSpektrum Demo
  secure_cookies: false
  csrf_key: "${FLOWSTATE_AUTH_CSRF_KEY}"
  allowed_origins:
    - localhost:*
    - 127.0.0.1:*

